class test_dataset(unittest.TestCase):
    def test_load_dataset(self):
        test_dataset_path = "./test/regression_test_datasets/";
        datapath = "./data/"
        load_ds = torch.load(test_dataset_path + "test_dataset.pt", map_location=DEVICE)
        new_ds,_ = create_ph_datasets(datapath);

        self.assertEqual(load_ds.aij_series.shape, new_ds.aij_series.shape)

        for (key, val) in load_ds.__dict__.items():
            if ((not '__' in key) and (not callable(val))): # user-defined obj
                if (torch.is_tensor(load_ds.__getattribute__(key))):
                    test_tensor = load_ds.__getattribute__(key);
                    new_tensor = new_ds.__getattribute__(key);
                    self.assertTrue(torch.equal(test_tensor, new_tensor))
                else:
                    test_attr = load_ds.__getattribute__(key);
                    new_attr = new_ds.__getattribute__(key);
                    self.assertEqual(test_attr, new_attr);
                    
class test_full_model_functionality(unittest.TestCase):
    def test_load_model(self):
        model_path = "./data/"
        ph_model = torch.load(model_path + "tmp_ph_model.pt", map_location=DEVICE)
        vis_model = torch.load(model_path + "tmp_vis_model.pt", map_location=DEVICE)
        ds = torch.load(model_path + "ldtn_ph_nl3_nu100_dr0.2_M20_sym.pt", map_location=DEVICE)['test_dataset'];
        A0 = ds.aij_series;
        A0 = A0.reshape(A0.shape[0], A0.shape[1], 3,3)
        N = A0.shape[0]
        tau = ds.normalization;
        delta = torch.diag_embed(torch.ones(N,3)) #\delta_{ij}
        del_1 = torch.einsum('nij,nkl->nijkl', delta, delta);
        del_2 = torch.einsum('nik,njl->nijkl', delta, delta);
        del_3 = torch.einsum('nil,njk->nijkl', delta, delta);
        def forcing(_A):
            Da = 0.05/tau**2;
            Ds = 0.05/tau**2;
            return -(1/3)*torch.sqrt(Ds/5)*del_1 + (1/2)*(torch.sqrt(Ds/5)+torch.sqrt(Da/3))*del_2 + (1/2)*(torch.sqrt(Ds/5)-torch.sqrt(Da/3))*del_3;

        compute_aij_trajs_ldmtbnn(A0, ph_model, vis_model, forcing, 1, tau);
        return;

